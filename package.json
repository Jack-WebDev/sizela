{
	"name": "sizela",
	"private": true,
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"type": "module",
	"scripts": {
		"dev": "turbo dev",
		"build": "turbo build",
		"build:core": "pnpm --filter @sizela/core build",
		"jsr:publish": "node ./scripts/sync-jsr-versions.mjs publish",
		"release:list-jsr": "node ./scripts/sync-jsr-versions.mjs list",
		"release:sync-jsr": "node ./scripts/sync-jsr-versions.mjs sync",
		"release:publish": "pnpm changeset publish",
		"test": "pnpm run test:unit && pnpm run test:release-scripts",
		"test:unit": "vitest run",
		"test:release-scripts": "node --test scripts/*.test.mjs",
		"test:watch": "vitest",
		"lint": "biome check --write .",
		"check-types": "turbo check-types",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@changesets/cli": "^2.31.0",
		"@sizela/config": "workspace:*",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"turbo": "^2.9.16",
		"typescript": "^6",
		"vitest": "catalog:"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": [
			"biome check --write ."
		]
	},
	"packageManager": "pnpm@10.32.1"
}

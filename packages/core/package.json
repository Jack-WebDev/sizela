{
	"name": "@sizela/core",
	"version": "1.0.0",
	"description": "Utility library with zero runtime dependencies.",
	"type": "module",
	"main": "./dist/index.mjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs",
			"default": "./dist/index.mjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown src/index.ts --out-dir dist --dts --clean",
		"lint": "biome check --write .",
		"check-types": "tsc -p tsconfig.json --noEmit",
		"clean": "rimraf dist .turbo"
	},
	"keywords": [],
	"author": "Jack WebDev",
	"license": "ISC",
	"packageManager": "pnpm@10.32.1",
	"devDependencies": {
		"rimraf": "catalog:",
		"tsdown": "catalog:"
	}
}
